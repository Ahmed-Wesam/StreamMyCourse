{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DescribeEdgeHostingStacks",
      "Effect": "Allow",
      "Action": "cloudformation:DescribeStacks",
      "Resource": [
        "arn:aws:cloudformation:us-east-1:YOUR_AWS_ACCOUNT_ID:stack/StreamMyCourse-EdgeHosting-dev/*",
        "arn:aws:cloudformation:us-east-1:YOUR_AWS_ACCOUNT_ID:stack/StreamMyCourse-EdgeHosting-prod/*"
      ]
    },
    {
      "Sid": "S3EdgeSiteBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:ListBucket",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::streammycourse-site-dev-us-east-1-YOUR_AWS_ACCOUNT_ID",
        "arn:aws:s3:::streammycourse-site-dev-us-east-1-YOUR_AWS_ACCOUNT_ID/*",
        "arn:aws:s3:::streammycourse-site-prod-us-east-1-YOUR_AWS_ACCOUNT_ID",
        "arn:aws:s3:::streammycourse-site-prod-us-east-1-YOUR_AWS_ACCOUNT_ID/*",
        "arn:aws:s3:::streammycourse-teacher-dev-us-east-1-YOUR_AWS_ACCOUNT_ID",
        "arn:aws:s3:::streammycourse-teacher-dev-us-east-1-YOUR_AWS_ACCOUNT_ID/*",
        "arn:aws:s3:::streammycourse-teacher-prod-us-east-1-YOUR_AWS_ACCOUNT_ID",
        "arn:aws:s3:::streammycourse-teacher-prod-us-east-1-YOUR_AWS_ACCOUNT_ID/*"
      ]
    },
    {
      "Sid": "CloudFrontInvalidation",
      "Effect": "Allow",
      "Action": "cloudfront:CreateInvalidation",
      "Resource": [
        "arn:aws:cloudfront::YOUR_AWS_ACCOUNT_ID:distribution/*"
      ]
    }
  ]
}
