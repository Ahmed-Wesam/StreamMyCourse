# Local environment variables for development (copy to .env.local and fill in values)
# DO NOT COMMIT .env.local - it is already in .gitignore

# AWS Region (defaults to eu-west-1 if not set)
# AWS_REGION=eu-west-1

# =============================================================================
# INTEGRATION TESTS
# =============================================================================

# Password for the primary dev Cognito test user (teacher A)
# LOCAL_COGNITO_PASSWORD=your-password-here

# Cognito username for integration tests (defaults to ci-rds-verify@noreply.local)
# LOCAL_COGNITO_USERNAME=ci-rds-verify@noreply.local

# Password for the alternate teacher user (teacher B) - used for cross-user access tests
# LOCAL_COGNITO_PASSWORD_ALT=your-alt-password-here

# Username for the alternate teacher user
# LOCAL_COGNITO_USERNAME_ALT=ci-rds-verify-2@noreply.local

# Password for the student user - used for student permission and enrollment tests
# LOCAL_COGNITO_PASSWORD_STUDENT=your-student-password-here

# Username for the student user
# LOCAL_COGNITO_USERNAME_STUDENT=ci-student@noreply.local

# Skip JWT minting for integration tests (set to 1 to run without auth)
# SKIP_JWT=1
