# Required: base URL for the catalog REST API (no trailing slash).
# Local dev with Vite proxy (see vite.student.config.ts): browser calls same-origin /api.
VITE_API_BASE_URL=/api

# Required for `npm run dev` / Vite dev when VITE_API_BASE_URL=/api: target API root (no trailing slash).
# VITE_API_PROXY_TARGET=https://xxxxxxxx.execute-api.eu-west-1.amazonaws.com/dev

# Production / direct API (no proxy): use your API Gateway invoke URL root (no trailing slash).
# Dev hosted SPA → dev API (example):   ...amazonaws.com/dev
# Prod hosted SPA → prod API (example):  ...amazonaws.com/prod
# VITE_API_BASE_URL=https://xxxxxxxx.execute-api.eu-west-1.amazonaws.com/dev

# Optional: teacher SPA origin (no trailing slash) for the student catalog "Teach on StreamMyCourse" link. When unset, defaults to https://teach.streammycourse.com
# VITE_TEACHER_SITE_URL=http://localhost:5174
# VITE_TEACHER_SITE_URL=https://teach.dev.streammycourse.click

# Cognito (optional locally unless you exercise sign-in; required for production SPA builds when pool + client IDs are set)
# When pool id AND client id are set, Hosted UI domain is required — same rule as npm run build:student / build:teacher (scripts/check-cognito-spa-env.mjs) and SPA runtime auth (frontend/src/lib/auth.ts).
# Student SPA: use the student app client ID. Teacher SPA: use the teacher app client ID.
# VITE_COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
# VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_DOMAIN=your-prefix.auth.eu-west-1.amazoncognito.com
